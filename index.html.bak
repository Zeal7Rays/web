<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZSRK | Strategic Materials for Global Industries</title>

    <link rel="stylesheet" href="assets/css/main.css">

    <meta name="description"
          content="Global supplier of rare earth materials, strategic metals, high-purity materials and industrial commodities.">
</head>

<body>

<header>
    <div class="container nav-wrapper">

        <div class="logo">
            <a href="index.html">
               <img src="assets/images/logo.png" alt="ZSRK Logo">
            </a>
        </div>

        <nav>
            <ul>
                <li><a href="#">HOME</a></li>
                <li><a href="#">ABOUT</a></li>
                <li><a href="#">PRODUCTS</a></li>
                <li><a href="#">SOURCING</a></li>
                <li><a href="#">MARKET</a></li>
                <li><a href="#">CONTACT</a></li>
            </ul>
        </nav>

        <div class="lang-switch">
            KR | EN
        </div>

    </div>
</header>

<section class="hero">

    <div class="hero-overlay"></div>

    <div class="hero-content">

        <h1>
            Strategic Materials<br>
            for Global Industries
        </h1>

        <p>
            Reliable sourcing solutions for rare earths,
            strategic metals, high-purity materials
            and industrial commodities.
        </p>

        <div class="hero-buttons">

            <a href="#" class="btn btn-gold">
                VIEW PRODUCTS
            </a>

            <a href="#" class="btn btn-outline">
                REQUEST QUOTATION
            </a>

        </div>

    </div>

</section>

<section class="featured">

    <div class="container">

        <h2>Featured Products</h2>

        <div class="product-grid">

            <div class="product-card">
               <a href="product/ndpr-oxide.html">
                  NdPr Oxide
               </a>
            </div>
            <div class="product-card">NdPr Metal</div>
            <div class="product-card">Dysprosium Metal</div>
            <div class="product-card">Terbium Metal</div>
            <div class="product-card">Copper Powder</div>
            <div class="product-card">Tungsten</div>

        </div>

    </div>

</section>

<section class="about">

    <div class="container">

        <h2>Why ZSRK</h2>

        <div class="about-grid">

            <div>
                <h3>Global Supplier Network</h3>
                <p>Reliable sourcing from qualified partners worldwide.</p>
            </div>

            <div>
                <h3>Quality Assurance</h3>
                <p>Support for material verification and inspection services.</p>
            </div>

            <div>
                <h3>Export Logistics</h3>
                <p>Professional coordination for international deliveries.</p>
            </div>

            <div>
                <h3>Strategic Sourcing</h3>
                <p>Competitive procurement solutions for industrial customers.</p>
            </div>

        </div>

    </div>

</section>

<section class="contact">

    <div class="container">

        <h2>Contact Us</h2>

        <form>

            <input type="text" placeholder="Company Name">

            <input type="email" placeholder="Email">

            <input type="text" placeholder="Interested Product">

            <textarea rows="5"
                      placeholder="Message"></textarea>

            <button type="submit">
                SEND INQUIRY
            </button>

        </form>

    </div>

</section>

<footer>

    <div class="container">

        <h3>ZSRK</h3>

        <p>
            Strategic Materials & Global Resources
        </p>

        <p>
            Seoul, Republic of Korea
        </p>

        <p>
            sales@zsrkmaterials.com
        </p>

    </div>

</footer>

</body>
</html>