<!-- OVERVIEW -->

<section class="section">

    <div class="container">

        <div class="section-title">

            <h2>Product Overview</h2>

        </div>

        <div class="product-grid">

            <div class="product-card">
  
              <div class="product-image">

                <img src="../assets/images/tungsten-powder.jpg"
                     alt="Tungsten Powder">
              </div>
            
              <h3>Tungsten Powder</h3>
            
            </div>
          
            <div class="product-card">
              <div class="product-image">

                <img src="../assets/images/tungsten-powder-sem.jpg"
                     alt="Tungsten Powder SEM">
                     
              </div>
            
              <h3>Tungsten Powder SEM</h3>     
            
            </div>
        </div>  
            <div>

                <p>

                    Tungsten Powder is a high-purity refractory metal powder
                    featuring exceptional density, high melting point,
                    excellent corrosion resistance and superior mechanical performance.

                </p>

                <p>

                    Manufactured through the reduction of tungsten oxide
                    or ammonium paratungstate (APT),
                    Tungsten Powder offers uniform particle size distribution
                    and excellent flowability for demanding industrial applications.

                </p>

            </div>


    </div>

</section>

<!-- SPECIFICATION -->
<section class="section bg-light">

    <div class="container">

        <div class="section-title">

            <h2>Typical Specifications</h2>

        </div>

        <table class="spec-table">

            <tr>
                <td>CAS Number</td>
                <td>7440-33-7</td>
                <td></td>
            </tr>

            <tr>
                <td>Purity</td>
                <td>99.0 % - 99.999 %</td>
                <td></td>
            </tr>

            <tr>
                <td>Particle Size (F.S.S.S.)</td>
                <td>1.8 - 2.7 μm</td>
                <td>size up to 40.0 μm (Custom Available)</td>
            </tr>

            <tr>
                <td>Oxygen Content</td>
                <td>0.03 - 0.08 %</td>
                <td>depending on particle size</td>
            </tr>

            <tr>
                <td>Apparent Density</td>
                <td>2.5 - 2.7 g/cm³</td>
                <td>depending on particle size</td>
            </tr>
            
            <tr>
              <td>Melting Point</td>
              <td>3,400 °C</td>
              <td></td>
            </tr>

            <tr>
                <td>Appearance</td>
                <td>Dark Gray Metallic Powder</td>
                <td></td>
            </tr>

        </table>
        
        <p class="spec-note"> Detailed specifications and particle size distributions can be provided upon request. </p>

    </div>

</section>

