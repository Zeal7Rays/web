<section class="page-hero">

    <div class="container">

        <h1>Contact Us</h1>

        <p>
            Connect with our team for sourcing inquiries,
            quotations and strategic material requirements.
        </p>

    </div>

</section>



<section class="contact-section">

    <div class="container contact-grid">

        <div class="contact-info">

            <h2>Get In Touch</h2>

            <p>
                We support global sourcing of rare earth materials,
                strategic minerals, high purity metals and specialty products.
            </p>

            <div class="info-item">

                <h3>Email</h3>
                <p>sales@z7rays.com</p>

            </div>

            <div class="info-item">

                <h3>Location</h3>
                <p>#713-L1, 190 Gimpo Hangang9-ro, 75beon-gil, Gimpo-si, Gyeonggi-do, Republic of Korea</p>

            </div>

            <div class="info-item">

                <h3>Business Hours</h3>
                <p>Mon - Fri / 09:00 - 18:00 KST</p>

            </div>

        </div>

        <div class="contact-form-wrapper">
            <form
              class="contact-form"
              action="https://formspree.io/f/xqeoydbn"
              method="POST"
            >
            
                <input 
                  type="hidden" 
                  name="_subject" 
                  value="[ZEAL 7RAYS KOREA Inquiry] New Request"
                >
               
                <input 
                  type="hidden"
                  name="_next"
                  value="thank-you.html"
                >

                <input
                    type="text"
                    name="company"
                    placeholder="Company Name"
                    required
                >

                <input
                    type="text"
                    name="contact_person"
                    placeholder="Contact Person"
                    required
                >

                <input
                    type="email"
                    name="email"
                    placeholder="Email Address"
                    required
                >
                
                <input 
                  type="text"
                  name="country"
                  placeholder="Country"
                >


                <input
                    type="text"
                    name="material"
                    placeholder="Material of Interest"
                >
                
                <textarea
                    name="message"
                    rows="6"
                    placeholder="Please describe your inquiry..."
                    required
                ></textarea>
                
                <!-- Spam Protection -->
                <input
                  type="text"
                  name="_gotcha"
                  style="display:none"
                >
                
                <button type="submit">

                    Send Inquiry

                </button>
                
            </form>
            
            <p class="response-time">

              Have a question about rare earth materials,
              specialty metals, or sourcing requirements?

              <br><br>

              Send us your inquiry and our team will get back
              to you within 1–2 business days.

            </p>

        </div>

    </div>

</section>

